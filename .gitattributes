# Normalize line endings across PCs — stops phantom CRLF/LF diffs
* text=auto eol=lf

# Treat these as binary (never normalize)
*.png  binary
*.PNG  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.svg  text
*.mp4  binary
*.ico  binary
*.woff  binary
*.woff2 binary

# Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
